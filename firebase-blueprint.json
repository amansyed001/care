{
  "entities": {
    "User": {
      "title": "User",
      "description": "System users (Admins and Agents)",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "agent"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "Member": {
      "title": "Member",
      "description": "Health membership card holders",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "aadhar": { "type": "string" },
        "issueDate": { "type": "string", "format": "date-time" },
        "expiryDate": { "type": "string", "format": "date-time" },
        "agentId": { "type": "string" },
        "agentName": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "expired"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "phone", "issueDate", "expiryDate", "agentId", "status"]
    },
    "Hospital": {
      "title": "Hospital",
      "description": "Partner hospital profiles",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "logo": { "type": "string" },
        "image": { "type": "string" },
        "specialists": { "type": "array", "items": { "type": "string" } },
        "services": { "type": "array", "items": { "type": "string" } },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "discountInfo": { "type": "string" },
        "isVerified": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "image", "address", "phone", "isVerified"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles"
    },
    "/members/{memberId}": {
      "schema": "Member",
      "description": "Membership records"
    },
    "/hospitals/{hospitalId}": {
      "schema": "Hospital",
      "description": "Partner hospital directory"
    }
  }
}
